{
    "name": "akitanabe/igo-modern",
    "description": "PHP implementation of the Igo morphological analyzer.",
    "license": "MIT",
    "bin": [
        "bin/igo"
    ],
    "require": {
        "php": "^8.0",
        "symfony/console": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "IgoModern\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IgoModern\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "format": "mago format",
        "lint": "mago lint --fix",
        "analyze": "phpstan analyse"
    }
}
