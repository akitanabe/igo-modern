{
    "name": "igo/igo-php8",
    "description": "PHP implementation of the Igo morphological analyzer.",
    "license": "MIT",
    "require": {
        "php": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "classmap": [
            "lib/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "format": "mago format",
        "lint": "mago lint --fix",
        "analyze": "phpstan analyse"
    }
}
